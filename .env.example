# JobCopilot environment variables
#
# Copy this file to .env.local for local development.
# Configure the same keys in Vercel Project Settings before deploying.
# Never commit real secrets.

# Required in production. Prisma uses this to connect to Supabase Postgres.
# For Vercel Serverless, prefer the Supabase pooled connection string on port 6543.
# For Prisma migrations, use the direct connection string locally or in a controlled CI step.
DATABASE_URL="postgresql://postgres:[password]@[host]:6543/postgres?pgbouncer=true"

# Required if Supabase client/admin integrations are enabled.
# The current app primarily uses Prisma for persistence, but keep these configured
# for the Supabase project backing the deployment.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Temporary single-user mode until real authentication is added.
DEFAULT_USER_ID="demo-user"
DEFAULT_USER_EMAIL="demo@jobcopilot.local"
DEFAULT_USER_NAME="George"

# Required in production when users can save model API keys.
# Use a long random value and keep it stable across deployments.
MODEL_CONFIG_SECRET="replace-with-a-long-random-secret"

# Default AI provider.
# Supported values: mock, openai, deepseek, qwen, kimi, custom
AI_PROVIDER="mock"

# Required when AI_PROVIDER is not mock, unless the user has saved a model config.
# AI_API_KEY is the generic fallback. Provider-specific keys are optional.
AI_API_KEY=""
OPENAI_API_KEY=""
DEEPSEEK_API_KEY=""
QWEN_API_KEY=""
KIMI_API_KEY=""

# Optional provider overrides. Leave empty to use provider defaults.
AI_MODEL=""
AI_BASE_URL=""

# Upload limits. Vercel Serverless functions also have platform request limits.
MAX_UPLOAD_BYTES="8388608"

# Public app URL. Set this to the production Vercel URL after deployment.
APP_URL="http://localhost:3000"

# Local-only legacy API server settings. Not required on Vercel.
API_PORT="8787"
DEV_CORS_ORIGIN="http://localhost:3000"
