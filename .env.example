# JobCopilot 环境变量示例
#
# 本地开发可复制为 .env.local
# 部署到 Vercel 时，请在 Project Settings -> Environment Variables 中同步配置

# 数据库连接
# 生产环境建议使用 Supabase pooled connection（通常为 6543 端口）
DATABASE_URL="postgresql://postgres:[password]@[host]:6543/postgres?pgbouncer=true"

# Supabase Auth / 客户端
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# 仅在后续需要服务端管理能力或 webhook 时使用，本阶段登录主链路不依赖它
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Supabase Storage 私有 bucket，用于保存上传的简历/JD 原文件
DOCUMENTS_BUCKET="jobcopilot-documents"

# 站点地址
# 本地可用 http://localhost:3000
# 生产环境请改成正式 Vercel 域名
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 用户保存模型 Key 时使用的加密密钥
MODEL_CONFIG_SECRET="replace-with-a-long-random-secret"

# 默认 AI provider
# 支持：mock, openai, deepseek, qwen, kimi, custom
AI_PROVIDER="mock"

# 默认 AI key
# 当用户没有单独保存模型配置时，后端会回退到这些环境变量
AI_API_KEY=""
OPENAI_API_KEY=""
DEEPSEEK_API_KEY=""
QWEN_API_KEY=""
KIMI_API_KEY=""

# 可选 provider 覆盖
AI_MODEL=""
AI_BASE_URL=""

# 语音识别（模拟面试录音转文字）
ASR_PROVIDER="openai"
ASR_API_KEY=""
ASR_MODEL="gpt-4o-mini-transcribe"
ASR_MAX_AUDIO_BYTES="26214400"

# 上传大小限制
MAX_UPLOAD_BYTES="8388608"

# 仅本地旧开发链路使用，Vercel 不需要
API_PORT="8787"
DEV_CORS_ORIGIN="http://localhost:3000"
